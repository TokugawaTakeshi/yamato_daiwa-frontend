@require "../../Functionality.styl"
@require "../../GUI_Components.styl"


CrossBrowserStylesReset()
InitialGlobalCSS_Rules()


provideBadgeYDF_Component()
provideLinkYDF_Component()


.StaticPreviewAnywherePage--YDF

  PRIMARY_COLOR = #ff9068
  ACCENTED_COLOR = #fd746c


  Centerer__CustomMinAndMaxWidths({ maximalWidth: 960px })
  padding 12px 10px 24px


  &-TopHeading

    applyTextGeometryWithoutExtraSpaceCausedByLineHeight({
      fontSize: 32px,
      lineHeight: 36px,
      mustAllowWordsBreakingAnywhere: true
    })

    color ACCENTED_COLOR


  &-Navigation

    margin-top 12px


  &-SectionHeading

    applyTextGeometryWithoutExtraSpaceCausedByLineHeight({
      fontSize: 28px,
      lineHeight: 32px,
      mustAllowWordsBreakingAnywhere: true
    })

    font-weight bold
    color ACCENTED_COLOR


  &-SubsectionHeading

    applyTextGeometryWithoutExtraSpaceCausedByLineHeight({
      fontSize: 22px,
      lineHeight: 26px,
      mustAllowWordsBreakingAnywhere: true
    })

    font-weight bold
    color PRIMARY_COLOR


  &-PagesSubsubgroupHeading

    applyTextGeometryWithoutExtraSpaceCausedByLineHeight({
      fontSize: 18px,
      lineHeight: 20px,
      mustAllowWordsBreakingAnywhere: true
    })

    font-weight bold
    color: W3C_39_ShadesOfGray--YDF[24]


  &-CardsFlow

    PositionalRelationship({
      definitions:\
        (".StaticPreviewAnywherePage--YDF-SectionHeading" { retireFromIt: { y: 8px }, pushItFromSelf: { y: 16px } })\
        (".StaticPreviewAnywherePage--YDF-SubsectionHeading" { retireFromIt: { y: 8px }, pushItFromSelf: { y: 16px } })
    })


  &-Card

    display flex
    align-items center
    padding 6px
    column-gap 6px

    box-shadow 0 0 4px 1px alpha(black, 0.25)

    retireFromElementWithSameSelector({ y: 8px })
