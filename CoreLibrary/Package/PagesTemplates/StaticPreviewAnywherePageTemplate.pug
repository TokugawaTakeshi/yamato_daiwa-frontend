extends RegularWebPageTemplate.pug


block append Functionality

  include ../GUI_Components.pug

  -

    /**
     * @typedef {
     *   {
     *     heading?: string;
     *     pages: Array<Page>;
     *     sections: Array<Section>;
     *   }
     * } TableOfContentsElement
     *
     * @typedef {
     *   {
     *     {
     *       title: string;
     *       progressStatus: string;
     *     } &
     *     (
     *       { URI: string } |
     *       { linksList: Array<{ label: string; URI: string; }>; } |
     *       {
     *         linksTable: Array<{
     *           rowLabel: string;
     *           progressStatus: string;
     *           columns: Array<{ label: string; URI: string; }>;
     *         }>
     *       }
     *     )
     *   }
     * } Page
     *
     * @typedef {
     *   {
     *     heading: string;
     *     pages: Array<Page>;
     *     sections: Array<Section>
     *   }
     * } Section
     *
     */

    class StaticPreviewAnywherePage__YDF {

      /**
       * @type { string | undefined }
       * @private
       */
      static topHeading;

      /**
       * @type Array<TableOfContentsElement>
       * @private
       */
      static tableOfContents = [];

      /**
       * @public
       * @type {
       *   Readonly<{
       *     waitingForImplementation: string;
       *     implementationInProgress: string;
       *     improvementWaiting: string;
       *     improvementInProgress: string;
       *     fixingWaiting: string;
       *     fixingInProgress: string;
       *     specificationClarification: string;
       *     reviewWaiting: string;
       *     customerEvaluationWaiting: string;
       *     accepted: string;
       *   }>
       * }
       * @readonly
       */
      static PageDevelopmentProgressStatuses = {

        waitingForImplementation: "WAITING_FOR_IMPLEMENTATION",
        implementationInProgress: "IMPLEMENTATION_IN_PROGRESS",

        improvementWaiting: "IMPROVEMENT_WAITING",
        improvementInProgress: "IMPROVEMENT_IN_PROGRESS",

        fixingWaiting: "FIXING_WAITING",
        fixingInProgress: "FIXING_IN_PROGRESS",

        specificationClarification: "SPECIFICATION_CLARIFICATION",

        reviewWaiting: "REVIEW_WAITING",
        customerEvaluationWaiting: "CUSTOMER_EVALUATION_WAITING",

        accepted: "ACCEPTED"

      }

      /**
       * @param {
       *   Readonly<{
       *     topHeading: string;
       *     tableOfContents: Array<TableOfContentsElement>
       *     metadata: {
       *       locale?: string;
       *       title?: string;
       *       description?: string | null;
       *       keywords?: string | null;
       *       author?: string | null;
       *     };
       *     faviconURI?: string;
       *     AMP_VersionURI?: string;
       *     stylesSheetsURIs?: Array<string>;
       *     scriptsURIs: {
       *       atEndOfHead?: Array<string>;
       *       atEndOfBody: Array<string>;
       *     }
       *   }>
       * } options
       * @returns { typeof RegularWebPageTemplate__YDF }
       * @public
       */
      static configure(
        {
          topHeading,
          tableOfContents,
          ...regularWebPageTemplateOptions
        }
      ) {

        RegularWebPageTemplate__YDF.configure(regularWebPageTemplateOptions);

        StaticPreviewAnywherePage__YDF.topHeading = topHeading;
        StaticPreviewAnywherePage__YDF.tableOfContents = tableOfContents;

      }

    }

    /** @deprecated */
    const StaticPreviewAnywherePage = {

      PageDevelopmentProgressStatuses: {

        implementationWaiting: "IMPLEMENTATION_WAITING",
        implementationInProgress: "IMPLEMENTATION_IN_PROGRESS",

        improvementWaiting: "IMPROVEMENT_WAITING",
        improvementInProgress: "IMPROVEMENT_IN_PROGRESS",

        fixingWaiting: "FIXING_WAITING",
        fixingInProgress: "FIXING_IN_PROGRESS",

        specificationClarification: "SPECIFICATION_CLARIFICATION",

        reviewWaiting: "REVIEW_WAITING",
        customerEvaluationWaiting: "CUSTOMER_EVALUATION_WAITING",

        accepted: "ACCEPTED"
      },

      getPageLinkSpecificCSS_Class: pageDevelopmentProgressStatus => {

        switch (pageDevelopmentProgressStatus) {

          case StaticPreviewAnywherePage.PageDevelopmentProgressStatuses.implementationWaiting:
            return "AnywherePage-PageLink__ImplementationWaiting";
          case StaticPreviewAnywherePage.PageDevelopmentProgressStatuses.implementationInProgress:
            return "AnywherePage-PageLink__ImplementationInProgress";

          case StaticPreviewAnywherePage.PageDevelopmentProgressStatuses.improvementWaiting:
            return "AnywherePage-PageLink__ImprovementWaiting";
          case StaticPreviewAnywherePage.PageDevelopmentProgressStatuses.improvementInProgress:
            return "AnywherePage-PageLink__ImprovementInProgress";

          case StaticPreviewAnywherePage.PageDevelopmentProgressStatuses.fixingWaiting:
            return "AnywherePage-PageLink__FixingWaiting";
          case StaticPreviewAnywherePage.PageDevelopmentProgressStatuses.fixingInProgress:
            return "AnywherePage-PageLink__FixingInProgress";

          case StaticPreviewAnywherePage.PageDevelopmentProgressStatuses.specificationClarification:
            return "AnywherePage-PageLink__SpecificationClarification";
          case StaticPreviewAnywherePage.PageDevelopmentProgressStatuses.reviewWaiting:
            return "AnywherePage-PageLink__ReviewWaiting";
          case StaticPreviewAnywherePage.PageDevelopmentProgressStatuses.customerEvaluationWaiting:
            return "AnywherePage-PageLink__CustomerEvaluationWaiting";
          case StaticPreviewAnywherePage.PageDevelopmentProgressStatuses.accepted:
            return "AnywherePage-PageLink__Accepted";
        }
      },

      localization: null,
      setLocalization(newLocalization) {
        this.localization = newLocalization;
      }
    }


  include StaticPreviewAnywherePage/StaticPreviewAnywherePageLocalization.English.pug

  - StaticPreviewAnywherePage.setLocalization(StaticPreviewAnywherePageLocalization__English);


  mixin RegularWebPageTemplate-Link--YDF(properties)

    +Link--YDF({ internalURI: properties.URI })= properties.title || properties.label


  mixin RegularWebPageTemplate-LinksList--YDF(links)

    ul

      each link in links

        li

          +Link--YDF({ internalURI: link.URI })= link.label

  mixin RegularWebPageTemplate-Card--YDF(page)

    li.StaticPreviewAnywherePage--YDF-CardsFlow-Item

      +Badge--YDF({
        valueLabel: "In Progress",
        geometricModifiers: [ Badge__YDF.GeometricModifiers.pillShape ],
        decorativeVariation: Badge__YDF.DecorativeVariations.calmingBright
      })

      if page.URI

        +RegularWebPageTemplate-Link--YDF(page)

      else if page.linksList

        span= page.title

        ul

          each link in page.linksList

            li

              +Link--YDF({ internalURI: link.URI })= link.label

      else if page.linksTable

        table

          tbody

            each stateDependentVariation in page.linksTable

              tr

                th= stateDependentVariation.rowLabel

                each column in stateDependentVariation.columns

                  td

                    +RegularWebPageTemplate-Link--YDF(column)

  mixin RegularWebPageTemplate-SectionsFlow--YDF(sections)

    each section in sections

      h3.AnywherePage-PagesSubgroupHeading= section.heading

      if section.pages

        ul.StaticPreviewAnywherePage--YDF-CardsFlow

          each page in section.pages

            +RegularWebPageTemplate-Card--YDF(page)

      if section.sections

        +RegularWebPageTemplate-SectionsFlow--YDF(section.sections)


  //- --- Single page link ---------------------------------------------------------------------------------------------
  mixin PageLink(parametersObject)

    a.AnywherePage-PageLink(
      href= parametersObject.URI
      class= StaticPreviewAnywherePage.getPageLinkSpecificCSS_Class(parametersObject.progressStatus)
    )
      .AnywherePage-PageLink-ProgressBadge
        | #{StaticPreviewAnywherePage.localization.progressStatusBadgesText[parametersObject.progressStatus]}
      .AnywherePage-PageLink-Text= parametersObject.label


  mixin PageLinksGroup(parametersObject)

    .AnywherePage-SinglePageRelatedLinksGroup(
      class= StaticPreviewAnywherePage.getPageLinkSpecificCSS_Class(parametersObject.progressStatus)
    )

      .AnywherePage-SinglePageRelatedLinksGroup-ProgressBadge
        | #{StaticPreviewAnywherePage.localization.progressStatusBadgesText[parametersObject.progressStatus]}

      .AnywherePage-SinglePageRelatedLinksGroup-MainSection
        .AnywherePage-SinglePageRelatedLinksGroup-Heading= parametersObject.title
        each linkData in parametersObject.linksData
          a.AnywherePage-SinglePageRelatedLinksGroup-Link(href= linkData.URI)= linkData.label


block append Styles

  style

    include StaticPreviewAnywherePage/StaticPreviewAnywherePage.css


block append PageContent

  .AnywherePage

    block TableOfContents

    if StaticPreviewAnywherePage__YDF.topHeading

      h1.AnywherePage-TopHeading= StaticPreviewAnywherePage__YDF.topHeading

    nav.StaticPreviewAnywherePage--YDF-Navigation

      each element in StaticPreviewAnywherePage__YDF.tableOfContents

        if element.heading

          h2.AnywherePage-PagesGroupHeading= element.heading

        if element.pages

          ul.StaticPreviewAnywherePage--YDF-CardsFlow

            each page in element.pages

              +RegularWebPageTemplate-Card--YDF(page)

        if element.sections

          +RegularWebPageTemplate-SectionsFlow--YDF(element.sections)
